 :80 {
    route {
        handle /term/* {
            basic_auth {
                {$RUNCLAWD_BASIC_AUTH_USER} {$RUNCLAWD_BASIC_AUTH_HASH}
            }
            reverse_proxy runclawd:7681
        }

        handle /openclaw/* {
            basic_auth {
                {$RUNCLAWD_BASIC_AUTH_USER} {$RUNCLAWD_BASIC_AUTH_HASH}
            }
            reverse_proxy runclawd:7682
        }

        handle /explorer {
            redir /explorer/ 308
        }

        handle /explorer/* {
            basic_auth {
                {$RUNCLAWD_BASIC_AUTH_USER} {$RUNCLAWD_BASIC_AUTH_HASH}
            }
            reverse_proxy explorer:8000
        }

        handle /cdplite {
            basic_auth {
                {$RUNCLAWD_BASIC_AUTH_USER} {$RUNCLAWD_BASIC_AUTH_HASH}
            }
            root * /srv/cdplite
            rewrite * /index.html
            file_server
        }

        handle /browserless {
            redir /browserless/ 308
        }

        handle_path /browserless/* {
            basic_auth {
                {$RUNCLAWD_BASIC_AUTH_USER} {$RUNCLAWD_BASIC_AUTH_HASH}
            }
            reverse_proxy browserless:3000
        }

        handle {
            reverse_proxy runclawd:18789
        }
    }
}
